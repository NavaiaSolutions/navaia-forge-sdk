{
  "name": "navaia-forge",
  "version": "0.2.0",
  "description": "Official TypeScript/JavaScript SDK for the NavaiaForge platform",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./integrations/langgraph": {
      "import": {
        "types": "./dist/integrations/langgraph/index.d.ts",
        "default": "./dist/integrations/langgraph/index.js"
      },
      "require": {
        "types": "./dist/integrations/langgraph/index.d.cts",
        "default": "./dist/integrations/langgraph/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0 <1.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "navaia",
    "navaia-forge",
    "ai",
    "agents",
    "workforce",
    "sdk",
    "langgraph"
  ]
}
