# ═══════════════════════════════════════════════════════════
# NavaiaForge — Local Backend Environment
# ═══════════════════════════════════════════════════════════
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Generate secrets: openssl rand -hex 32

# ── Core ────────────────────────────────────────────────────
SECRET_KEY=replace-with-openssl-rand-hex-32
# DEBUG=true skips production security checks (required for local dev)
DEBUG=true

# ── Database (Postgres) ────────────────────────────────────
POSTGRES_USER=navaia_forge
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=navaia_forge

# ── Agent Runtime ──────────────────────────────────────────
# For navaia_code runtime — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# For claude_max runtime — install Claude Code CLI and run: claude login
# CLAUDE_CLI_PATH=claude

# ── Ports ──────────────────────────────────────────────────
API_PORT=8001

# ── Weaviate (Vector DB) ──────────────────────────────────
WEAVIATE_API_KEY=replace-with-openssl-rand-hex-32

# ── CORS (comma-separated origins) ────────────────────────
ALLOWED_ORIGINS=http://localhost:3030,http://localhost:3000
